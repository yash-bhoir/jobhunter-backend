# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourStrongAdminPassword
API_URL=http://localhost:5000

# ── MongoDB ───────────────────────────────────────────────────────
# If Atlas/DNS is broken on your PC, start API without a real DB (ephemeral, dev only):
#   npm run dev:local
# (Or set USE_IN_MEMORY_MONGO=1 and run npm run dev — never in production.)
#
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/job_search_db?retryWrites=true&w=majority
#
# Windows / some routers: Node can fail mongodb+srv with querySrv ECONNREFUSED while nslookup works.
# Set public resolvers for the Node process (dev only; omit on locked-down networks):
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
#
# Local Mongo (Docker):  docker compose up -d
# MONGODB_URI=mongodb://127.0.0.1:27017/job_search_db

# ── Map search (/geo-jobs/nearby) ─────────────────────────────────
# Default: always call Adzuna + JSearch + SerpAPI on each map search (when keys exist).
# GEO_NEARBY_SKIP_LIVE_FETCH=1  — skip external API calls (DB + existing GeoJob cache only).
# GEO_NEARBY_LIVE_LIMIT=250     — max cached API jobs returned per request (50–500).

# ── Redis ─────────────────────────────────────────────────────────
# Set to "skip" to disable Redis (uses in-memory fallback)
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=generate-a-strong-random-secret-here
JWT_REFRESH_SECRET=generate-another-strong-random-secret-here
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=30d
# Optional: allow sending refresh token in JSON body (e.g. non-browser clients). Web app uses httpOnly cookie only.
# ALLOW_REFRESH_TOKEN_BODY=false
# Dev-only auth helpers (/auth/dev/*) — default on when NODE_ENV=development; set false to disable.
# ALLOW_DEV_AUTH_ROUTES=false

# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Cloudinary ────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── GlobalJob semantic dedupe (optional; uses OpenAI embeddings) ───
# Set to 0/false to disable embedding calls during GlobalJob ingest
# GLOBAL_JOB_SEM_DEDUP=1
GLOBAL_JOB_SEM_DEDUP_THRESHOLD=0.88
GLOBAL_JOB_SEM_DEDUP_MAX_NEIGHBORS=40
# JOB_EMBEDDING_MODEL=text-embedding-3-small
# JOB_EMBEDDING_DIMENSIONS=512

# ── Job Search APIs ───────────────────────────────────────────────
RAPIDAPI_KEY=your-rapidapi-key
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# ── Optional Paid Job Sources (admin-controlled) ──────────────────
SERPAPI_KEY=your-serpapi-key
REED_API_KEY=your-reed-api-key

# ── Shared search cluster (cross-user API reuse) ───────────────────
# Hours a snapshot stays valid before the next user triggers fresh provider calls
SEARCH_CLUSTER_TTL_HOURS=24
# Min jobs in snapshot before reuse is allowed
SEARCH_CLUSTER_MIN_JOBS=20
# Max jobs stored per cluster (MongoDB single-doc limit)
SEARCH_CLUSTER_SNAPSHOT_MAX=200
# Sibling reuse: min Jaccard(role tokens) vs stored cluster; min jobs after role-text filter
SEARCH_CLUSTER_SIBLING_MIN_JACCARD=0.18
SEARCH_CLUSTER_SIBLING_MIN_AFTER_FILTER=20

# ── CareerJet v4 (publisher API) — https://www.careerjet.com/partners/register/as-publisher
# Basic auth user = API key, password empty. Requires real end-user IP (passed from search request).
CAREERJET_API_KEY=
# Legacy name — treated same as CAREERJET_API_KEY if set
# CAREERJET_AFFID=

# ── Email Finding ─────────────────────────────────────────────────
# Hunter.io — 50 free searches/month — https://hunter.io/api-keys
HUNTER_API_KEY=your-hunter-api-key

# Apollo.io — people search requires paid plan ($49/mo) — free plan gets org data only
# https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=your-apollo-api-key

# Snov.io — 50 free credits/month — https://app.snov.io/api-setting
# Register → Settings → API → copy Client ID + Client Secret
SNOV_CLIENT_ID=your-snov-client-id
SNOV_CLIENT_SECRET=your-snov-client-secret

# ── System Email ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=JobHunter <noreply@yourdomain.com>

# ── Razorpay ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Security ──────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# AES-256-GCM key for encrypting SMTP passwords and Gmail OAuth tokens in MongoDB.
# Must be exactly 64 hex characters (32 bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=generate-with-node-command-above-64-hex-chars
